\begin{tikzpicture}
  \begin{axis}[
    name=phasediag,
    width=0.75\columnwidth,
    height=0.7\columnwidth,
    xlabel={$\phi_\mathrm{NS}=C_\mathrm{NS}/C_\mathrm{ov}$},
    ylabel={$T$ ($^\circ$C)},
    xmin=0, xmax=0.55,
    ymin=0, ymax=100,
	ylabel near ticks, ylabel shift=-0.5em,
    %tick label style={font=\large},
    %label style={font=\Large},
    %major tick length=5pt,
    clip=true,
  ]    

	\fill[lightgray] (axis cs:1314/2028,0) rectangle (rel axis cs:1,1);
    \addplot[ultra thick, BurntOrange, no marks]
      table[x expr=\thisrowno{0}/1.5/2028, y index=3]
      {simulations/mfold_SE6_concentration.tsv};
    \node[BurntOrange, anchor=base west, inner xsep=5pt] at (axis cs:0,60)
      {non-percolated nanostars};
    \node[BurntOrange, anchor=base west, inner xsep=5pt] at (axis cs:0,37)
      {$T_{SE}$};  

	\addplot[mark=*] coordinates {(894/2028,20)};
	\addplot[mark=square] coordinates {(268/2028,25)};

    \draw[ultra thick, Gray, dashed]
      (axis cs:894/2028, 0) -- (axis cs:894/2028,20)
      to[out=90, in=0] (axis cs:894/2028/2,38.8)
      node[anchor=south west, inner xsep=5pt] at (axis cs:0,10) {phase separation region};

	
      
    %\node[Plum, text width=5em, align=center, anchor=south] at (axis cs:0.49,10) {bulk\linebreak gel};
	\node[Plum, anchor=base east, inner xsep=5pt] at (axis cs:0.55,35) {bulk gel};

    \addplot[ultra thick, SkyBlue, no marks]
