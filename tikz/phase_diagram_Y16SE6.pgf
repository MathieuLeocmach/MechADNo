    \node[SkyBlue, anchor=north east] at (rel axis cs:0.15,0.90)
      {$T_{NS}$};

    %\draw[->, ultra thick, Plum] (axis cs:1000/2028,95) -- (axis cs:1000/2028,35);
	\draw[->, ultra thick, BurntOrange] (axis cs:1000/2028,75) -- (axis cs:1000/2028,55);
